# ===== Banco (Neon Postgres — serverless, "sempre ligado") =====
# No painel do Neon (Dashboard > Connection Details), copie as duas strings.
# Use a POOLED (host com "-pooler") para a app e a DIRECT para migrations.
DATABASE_URL="postgresql://USER:PASS@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASS@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# ===== Auth.js =====
# gere com: openssl rand -base64 32
AUTH_SECRET="troque-este-valor"
AUTH_URL="http://localhost:3000"

# ===== Resend (e-mail de orçamento) — pode deixar vazio no Bloco 1 =====
RESEND_API_KEY=""
QUOTE_FROM_EMAIL="orcamentos@jg2.com.br"
QUOTE_TO_EMAIL="administracao@jg2.com.br"

# ===== Cloudflare R2 (imagens) — pode deixar vazio no Bloco 1 =====
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="jg2-produtos"
R2_PUBLIC_URL=""
# Mesmo valor de R2_PUBLIC_URL acima, exposto ao client — usado por resolveImageUrl()
# pra montar a URL absoluta que o otimizador de imagens do next/image consegue buscar
# direto (ele não segue o redirect /uploads/* → R2 definido no next.config.ts).
NEXT_PUBLIC_R2_PUBLIC_URL=""

# ===== reCAPTCHA v3 (formulários públicos) — pode deixar vazio; sem as chaves,
# a verificação é pulada e os formulários continuam funcionando normalmente =====
# Gere em https://www.google.com/recaptcha/admin/create (tipo "reCAPTCHA v3", registre o domínio + localhost)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
